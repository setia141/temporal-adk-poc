# OpenAI API key used by LiteLLM inside the ADK agents. Can also live in your
# machine/profile environment — python-dotenv never overrides an existing var.
OPENAI_API_KEY=sk-...

# Model name passed to LiteLLM, prefixed with the provider per litellm convention:
# openai/..., azure/..., anthropic/..., gemini/..., vertex_ai/..., bedrock/..., etc.
# See https://docs.litellm.ai/docs/providers for each provider's required env vars.
ADK_MODEL=openai/gpt-4o-mini

# --- Custom org gateway (optional) ---
# Routes every litellm-backed model call through your gateway with extra headers.
# When either var is set, runner/gateway_litellm.py registers a LiteLlm subclass
# in ADK's LLMRegistry with these baked in (the plugin's invoke_model activity
# rebuilds the LLM from just the model-name string, so constructor kwargs can't
# be passed per-call). Headers: comma-separated key=value pairs, no spaces
# around "=". Restart worker.py after changing; the startup log shows
# "Updating LLM class ... GatewayLiteLlm" lines when active.
# AI_GATEWAY_BASE_URL=https://your-gateway/v1
# AI_GATEWAY_HEADERS=X-Api-Key=abc123,X-Tenant-Id=my-org

# Gateway shaped like Azure OpenAI (https://your-gateway/openai/deployments/{model}):
# use the "azure/" provider instead — litellm builds that URL shape natively.
# AZURE_API_BASE is the bare host (litellm appends /openai/deployments/...).
# ADK_MODEL=azure/your-deployment-name
# AZURE_API_BASE=https://your-gateway
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-06-01

# Attachment storage backend: "inline" (default, refs ride through Temporal
# payloads) or "azure_blob" (requires AZURE_STORAGE_CONNECTION_STRING).
# ATTACHMENT_STORE=inline

# Temporal server address (defaults to local dev server).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adk-agents-task-queue
