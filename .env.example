# OpenAI credentials used by LiteLLM inside the ADK agents.
OPENAI_API_KEY=sk-...

# Model name passed to LiteLLM, prefixed with the provider per litellm convention:
# openai/..., azure/..., anthropic/..., gemini/..., vertex_ai/..., bedrock/..., etc.
# See https://docs.litellm.ai/docs/providers for the full list and each provider's
# required env vars (API key, base URL, ...).
ADK_MODEL=openai/gpt-4o-mini

# Optional: custom org gateway for every litellm-routed model call. When either
# var is set, runner/gateway_litellm.py registers a LiteLlm subclass in ADK's
# LLMRegistry that constructs every model with api_base=AI_GATEWAY_BASE_URL and
# extra_headers=AI_GATEWAY_HEADERS — necessary because the plugin's invoke_model
# activity rebuilds the LLM from just the model-name string, so constructor
# kwargs can't be passed per-call. Headers are comma-separated key=value pairs,
# no spaces around "=". Leave both unset to call the provider directly.
# AI_GATEWAY_BASE_URL=https://company-gateway/v1
# AI_GATEWAY_HEADERS=X-Api-Key=abc123,X-Tenant-Id=my-org

# Gateway shaped like Azure OpenAI (https://your-gateway/openai/deployments/{model}):
# use the "azure/" provider — litellm builds exactly that URL shape itself.
# AZURE_API_BASE must be the bare host (litellm appends /openai/deployments/...).
# ADK_MODEL=azure/your-deployment-name
# AZURE_API_BASE=https://your-gateway
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-06-01    # required by litellm's azure client

# Attachment storage backend: "inline" (default, refs ride through Temporal
# payloads) or "azure_blob" (requires AZURE_STORAGE_CONNECTION_STRING).
# ATTACHMENT_STORE=inline

# Temporal server address (defaults to local dev server).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adk-agents-task-queue
