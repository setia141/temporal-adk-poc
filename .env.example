# OpenAI credentials used by LiteLLM inside the ADK agents.
OPENAI_API_KEY=sk-...

# Optional: point litellm at an OpenAI-compatible gateway instead of api.openai.com
# (e.g. a self-hosted LiteLLM proxy, Azure OpenAI gateway, etc). Leave unset to
# call OpenAI directly. Every provider below reads its own base-URL env var the
# same way (AZURE_API_BASE, ANTHROPIC_API_BASE, ...) — litellm handles it, not
# our code.
# OPENAI_API_BASE=https://your-litellm-gateway.example.com/v1

# Optional: extra HTTP headers to send with every model call, for a gateway that
# needs more than just the provider's own API key header (a second auth header,
# a tenant/routing header, etc). Comma-separated key=value pairs, no spaces
# around "=". Applies to every provider below — runner/agent_runner.py always
# constructs LiteLlm(...) directly, so this is one kwarg (extra_headers=...),
# not per-provider wiring.
# AI_GATEWAY_HEADERS=X-Api-Key=abc123,X-Tenant-Id=my-org

# Model name passed to LiteLLM, prefixed with the provider per litellm convention:
# openai/..., azure/..., anthropic/..., gemini/..., vertex_ai/..., bedrock/..., etc.
# See https://docs.litellm.ai/docs/providers for the full list and each
# provider's required env vars (API key, base URL, ...).
ADK_MODEL=openai/gpt-4o-mini

# --- Example: org gateway shaped like Azure OpenAI (.../openai/deployments/{model}) ---
# ADK_MODEL=azure/your-deployment-name
# AZURE_API_BASE=https://your-gateway            # bare host; litellm appends /openai/deployments/...
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-06-01                    # required by litellm's azure client

# --- Example: org gateway for Gemini (.../v1beta/models/{model}) ---
# ADK_MODEL=gemini/gemini-2.0-flash               # litellm's own Gemini provider (not ADK's native one)
# GEMINI_API_BASE=https://your-gateway
# GEMINI_API_KEY=...

# Temporal server address (defaults to local dev server).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adk-agents-task-queue
