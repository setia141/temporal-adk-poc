# OpenAI credentials used by LiteLLM inside the ADK agents.
OPENAI_API_KEY=sk-...

# Optional: point litellm at an OpenAI-compatible gateway instead of api.openai.com
# (e.g. a self-hosted LiteLLM proxy, Azure OpenAI gateway, etc). Leave unset to
# call OpenAI directly.
# OPENAI_API_BASE=https://your-litellm-gateway.example.com/v1

# Optional: extra HTTP headers to send with every model call, for gateways that
# need more than just OPENAI_API_KEY (a second API key header, a tenant/routing
# header, etc). Comma-separated key=value pairs, no spaces around "=".
# AI_GATEWAY_HEADERS=X-Api-Key=abc123,X-Tenant-Id=my-org

# Model name passed to LiteLLM, prefixed with the provider per litellm convention
# (openai/..., anthropic/..., vertex_ai/..., azure/..., bedrock/..., etc).
# OPENAI_API_BASE/AI_GATEWAY_HEADERS above apply to every litellm-routed provider,
# not just OpenAI, since they're all the same litellm.completion() call underneath.
#
# A BARE model name with no provider prefix (gemini-2.0-flash, claude-sonnet-4-...)
# takes a completely different path: ADK's own native Gemini/Claude classes, which
# call google.genai / anthropic directly and never go through litellm — so
# OPENAI_API_BASE and AI_GATEWAY_HEADERS do NOT apply to those.
ADK_MODEL=openai/gpt-4o-mini

# --- Org gateway shaped like Azure OpenAI (https://your-gateway/openai/deployments/{model}) ---
# Use the "azure/" litellm provider instead of "openai/" — it builds exactly that
# URL shape. AZURE_API_BASE must be the bare host (no /openai/deployments/... suffix,
# litellm appends that itself using the model name after "azure/").
# ADK_MODEL=azure/your-deployment-name
# AZURE_API_BASE=https://comany-gateway
# AZURE_API_KEY=...
# AZURE_API_VERSION=2024-06-01               # required by litellm's azure client even if your gateway ignores it
# AI_GATEWAY_HEADERS=X-Extra-Auth=token123   # any headers beyond AZURE_API_KEY's api-key header

# --- Org gateway for Gemini (https://your-gateway/v1beta/models/{model}) ---
# Bare "gemini-..." model names use ADK's native Gemini class (google.genai),
# not litellm, so this is a different pair of env vars, not OPENAI_API_BASE.
# ADK_MODEL=gemini-2.0-flash
# GOOGLE_GEMINI_BASE_URL=https://company-gateway
# GOOGLE_API_KEY=...
# AI_GATEWAY_HEADERS above is also reused here (runner/gateway_gemini.py) for
# any headers beyond GOOGLE_API_KEY's x-goog-api-key header — google.genai has
# no built-in equivalent of litellm.headers, so a small Gemini subclass handles
# it, registered automatically only when AI_GATEWAY_HEADERS is set.

# Temporal server address (defaults to local dev server).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adk-agents-task-queue
