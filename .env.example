# OpenAI credentials used by LiteLLM inside the ADK agents.
OPENAI_API_KEY=sk-...

# Optional: point litellm at an OpenAI-compatible gateway instead of api.openai.com
# (e.g. a self-hosted LiteLLM proxy, Azure OpenAI gateway, etc). Leave unset to
# call OpenAI directly.
# OPENAI_API_BASE=https://your-litellm-gateway.example.com/v1

# Model name passed to LiteLLM, prefixed with the provider per litellm convention.
ADK_MODEL=openai/gpt-4o-mini

# Temporal server address (defaults to local dev server).
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=adk-agents-task-queue
